{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "hyprshutdown",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown -t 'Rebooting...' -p 'systemctl reboot'",
    "text" : "Reboot",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown -t 'Shutting down...' -p 'systemctl poweroff'",
    "text" : "Shutdown",
    "keybind" : "s"
}
