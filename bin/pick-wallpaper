#!/bin/bash

# Interactive wallpaper picker using rofi with thumbnail grid.
# Requires: imagemagick (magick), rofi, change-wallpaper

set -euo pipefail

WALLPAPERS_DIR="$HOME/Pictures/Wallpapers/current"
CACHE_DIR="$HOME/.cache/wallpaper-thumbnails"
THUMB_SIZE=220

if [[ ! -d "$WALLPAPERS_DIR" ]]; then
    notify-send "Wallpaper directory does not exist: $WALLPAPERS_DIR" -u critical -t 3000
    exit 1
fi

if ! command -v magick >/dev/null 2>&1; then
    notify-send "ImageMagick (magick) is required for thumbnail generation" -u critical -t 3000
    exit 1
fi

mkdir -p "$CACHE_DIR"

# Generate thumbnails and build rofi entries
ENTRIES=""

while IFS= read -r -d '' wallpaper; do
    name="$(basename "$wallpaper")"
    thumb="$CACHE_DIR/${name}.png"

    # Regenerate thumbnail if missing or older than source
    if [[ ! -f "$thumb" ]] || [[ "$wallpaper" -nt "$thumb" ]]; then
        magick "$wallpaper" \
            -resize "${THUMB_SIZE}x${THUMB_SIZE}^" \
            -gravity center \
            -extent "${THUMB_SIZE}x${THUMB_SIZE}" \
            "$thumb"
    fi

    # rofi dmenu format: display-text\0icon\x1f/path/to/icon
    ENTRIES+="${wallpaper}\0icon\x1f${thumb}\n"
done < <(find "$WALLPAPERS_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) -print0 | sort -z)

if [[ -z "$ENTRIES" ]]; then
    notify-send "No wallpapers found in $WALLPAPERS_DIR" -u critical -t 3000
    exit 1
fi

# Show rofi picker with wallpaper grid theme
SELECTED=$(echo -en "$ENTRIES" | rofi -dmenu \
    -show-icons \
    -theme "$HOME/.config/rofi/themes/wallpaper-grid.rasi") || true

[[ -z "$SELECTED" ]] && exit 0

if [[ ! -f "$SELECTED" ]]; then
    notify-send "Could not resolve wallpaper selection" -u critical -t 3000
    exit 1
fi

change-wallpaper "$SELECTED"
